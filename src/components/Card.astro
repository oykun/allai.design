---
const { item } = Astro.props;
const { title, source, type, category, style, tags, sourceUrl, imageUrl, videoUrl } = item;
---

<article
  class="card"
  data-source={source}
  data-type={type}
  data-category={category}
  data-style={style.join(',')}
  data-tags={tags.join(',')}
>
  <a href={sourceUrl} target="_blank" rel="noopener noreferrer" class="card-image">
    {videoUrl
      ? <video src={videoUrl} poster={imageUrl || undefined} autoplay muted loop playsinline preload="auto" disablepictureinpicture disableremoteplayback />
      : imageUrl
        ? <img src={imageUrl} alt={title} loading="lazy" />
        : <div class="card-image-placeholder">no image</div>
    }
  </a>
</article>
