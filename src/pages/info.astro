---
import SideNav from '../components/SideNav.astro';
import '../styles/global.css';
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Info — allai.design</title>
  <meta name="description" content="About allai.design — curated AI product UI, design patterns, and tools for designers building with AI." />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
</head>
<body>

  <aside class="side-panel">
    <div class="side-panel-inner">
      <SideNav active="info" />
    </div>
  </aside>

  <main class="info-page">
    <p>allai.design is a curated resource at the intersection of AI and design. Your single source for everything AI as a designer.</p>
    <p>Created and curated tastefully by <a href="https://x.com/oykun" target="_blank" rel="noopener noreferrer">@oykun</a>, founder and creative lead of <a href="https://crucial.design" target="_blank" rel="noopener noreferrer">Crucial.Design</a> agency.</p>
  </main>

</body>
</html>

<style>
.info-page {
  max-width: 400px;
  padding: 64px 24px 120px;
  display: flex;
  flex-direction: column;
  gap: 16px;
}

.info-page p {
  color: var(--text-primary);
  line-height: 1.7;
}

.info-page a {
  text-decoration: underline;
  text-underline-offset: 3px;
}

@media (max-width: 640px) {
  .info-page { padding: 40px 16px 80px; }
}
</style>
