---
import { getPublishedItems, getUnique, getUniqueMulti } from '../lib/notion.js';
import Card from '../components/Card.astro';
import SideNav from '../components/SideNav.astro';
import '../styles/global.css';

const items = await getPublishedItems();
const sources = getUnique(items, 'source');
const types = getUnique(items, 'type');
const categories = getUnique(items, 'category');
const styles = getUniqueMulti(items, 'style');
const tags = getUniqueMulti(items, 'tags');
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>allai.design — AI design, curated</title>
  <meta name="description" content="Curated AI product UI, design patterns, and tools for designers building with AI." />
  <meta property="og:title" content="allai.design" />
  <meta property="og:description" content="Curated AI product UI, design patterns, and tools for designers building with AI." />
  <meta property="og:type" content="website" />
  <meta property="og:url" content="https://allai.design" />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
</head>
<body>

  <aside class="side-panel">
    <div class="side-panel-inner">

      <SideNav active="feed" />

      <div class="side-section">
        <div class="filter-group-label">Source</div>
        <ul class="filter-list">
          <li><button class="filter-opt active" data-group="source" data-value="all"><span class="filter-dot"></span>All</button></li>
          {sources.map(s => (
            <li><button class="filter-opt" data-group="source" data-value={s}><span class="filter-dot"></span>{s}</button></li>
          ))}
        </ul>
      </div>

      <div class="side-section">
        <div class="filter-group-label">Type</div>
        <ul class="filter-list">
          <li><button class="filter-opt active" data-group="type" data-value="all"><span class="filter-dot"></span>All</button></li>
          {types.map(t => (
            <li><button class="filter-opt" data-group="type" data-value={t}><span class="filter-dot"></span>{t}</button></li>
          ))}
        </ul>
      </div>

      <div class="side-section">
        <div class="filter-group-label">Category</div>
        <ul class="filter-list">
          <li><button class="filter-opt active" data-group="category" data-value="all"><span class="filter-dot"></span>All</button></li>
          {categories.map(c => (
            <li><button class="filter-opt" data-group="category" data-value={c}><span class="filter-dot"></span>{c}</button></li>
          ))}
        </ul>
      </div>

      <div class="side-section">
        <div class="filter-group-label">Style</div>
        <ul class="filter-list">
          <li><button class="filter-opt active" data-group="style" data-value="all"><span class="filter-dot"></span>All</button></li>
          {styles.map(s => (
            <li><button class="filter-opt" data-group="style" data-value={s}><span class="filter-dot"></span>{s}</button></li>
          ))}
        </ul>
      </div>

      {tags.length > 0 && (
        <div class="side-section">
          <div class="filter-group-label">Tag</div>
          <ul class="filter-list">
            <li><button class="filter-opt active" data-group="tag" data-value="all"><span class="filter-dot"></span>All</button></li>
            {tags.map(t => (
              <li><button class="filter-opt" data-group="tag" data-value={t}><span class="filter-dot"></span>{t}</button></li>
            ))}
          </ul>
        </div>
      )}

      <div class="side-section side-count">
        <span id="count">{items.length} items</span>
      </div>

    </div>
  </aside>

  <main id="grid-container">
    {items.length > 0 ? (
      <div class="grid" id="grid">
        {items.map((item, i) => (
          <Card item={item} index={i} />
        ))}
      </div>
    ) : (
      <div class="empty-state">Nothing published yet.</div>
    )}
  </main>

</body>
</html>

<style>
body {
  margin: 0;
  overflow-x: hidden;
}

/* Full-bleed grid */
#grid-container {
  width: 100vw;
}

.grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
  gap: 1rem;
  padding: 1rem;
  align-items: start;
}

/* Filter sections */
.filter-group-label {
  color: var(--text-muted);
  margin-bottom: 6px;
}

.filter-list {
  list-style: none;
  display: flex;
  flex-direction: column;
  gap: 1px;
}

.filter-opt {
  display: flex;
  align-items: center;
  justify-content: flex-end;
  gap: 7px;
  font-size: inherit;
  font-family: var(--font);
  color: var(--text-muted);
  background: none;
  border: none;
  cursor: pointer;
  padding: 2px 0;
  width: 100%;
  text-align: right;
  line-height: 1.4;
  transition: color 0.1s;
}

.filter-opt:hover { color: var(--text-primary); }
.filter-opt:hover .filter-dot { border-color: var(--text-primary); }

.filter-opt.active {
  color: var(--text-primary);
  font-weight: 500;
}

.filter-opt.active .filter-dot {
  background: var(--text-primary);
  border-color: var(--text-primary);
}

.filter-dot {
  width: 6px;
  height: 6px;
  border-radius: 50%;
  border: 1.5px solid var(--text-muted);
  flex-shrink: 0;
  order: 1; /* dot after text (right side) */
  transition: all 0.1s;
}

</style>

<script>
  // Force-autoplay every video, no interaction required. The autoplay attribute
  // alone is enough in most browsers, but some (Brave, locked-down Firefox,
  // certain embedded webviews) silently ignore it. Setting `muted` as a JS
  // property (not just the HTML attribute) and calling play() explicitly is
  // the reliable cross-browser way to guarantee it actually starts.
  function forcePlay(video: HTMLVideoElement) {
    video.muted = true;
    video.playsInline = true;
    const attempt = () => video.play().catch(() => {
      // Autoplay can still be rejected in rare cases (e.g. data-saver mode).
      // Retry once on next paint rather than leaving it stuck on the poster.
      requestAnimationFrame(() => video.play().catch(() => {}));
    });
    if (video.readyState >= 2) attempt();
    else video.addEventListener('loadeddata', attempt, { once: true });
  }

  document.querySelectorAll('video').forEach(v => forcePlay(v as HTMLVideoElement));

  const cards = document.querySelectorAll('.card');
  const count = document.getElementById('count');

  const active: Record<string, string> = {
    source: 'all',
    type: 'all',
    category: 'all',
    style: 'all',
    tag: 'all',
  };

  function applyFilters() {
    let visible = 0;
    cards.forEach(card => {
      const el = card as HTMLElement;
      const matches =
        (active.source === 'all' || el.dataset.source === active.source) &&
        (active.type === 'all' || el.dataset.type === active.type) &&
        (active.category === 'all' || el.dataset.category === active.category) &&
        (active.style === 'all' || (el.dataset.style || '').split(',').includes(active.style)) &&
        (active.tag === 'all' || (el.dataset.tags || '').split(',').includes(active.tag));
      el.style.display = matches ? '' : 'none';
      if (matches) {
        visible++;
        const video = el.querySelector('video');
        if (video) forcePlay(video as HTMLVideoElement);
      }
    });
    count!.textContent = `${visible} items`;
  }

  document.querySelectorAll('.filter-opt').forEach(btn => {
    btn.addEventListener('click', () => {
      const el = btn as HTMLElement;
      const group = el.dataset.group!;
      const value = el.dataset.value!;
      active[group] = value;
      document.querySelectorAll(`.filter-opt[data-group="${group}"]`).forEach(b => b.classList.remove('active'));
      btn.classList.add('active');
      applyFilters();
    });
  });
</script>
