# Notion integration token
# Get from: https://www.notion.so/my-integrations → create integration → copy token
NOTION_TOKEN=secret_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Notion database ID — the Content Queue database
# From the URL: https://app.notion.com/p/ae146257094c499bbd8a4cc2932920c0
NOTION_DATABASE_ID=ae146257094c499bbd8a4cc2932920c0

# Cloudflare R2 — media hosting (images + video re-hosted from source CDNs)
# Get these from: Cloudflare dashboard → R2 → Manage API tokens → Create API token
R2_ACCOUNT_ID=your_cloudflare_account_id
R2_ACCESS_KEY_ID=your_r2_access_key_id
R2_SECRET_ACCESS_KEY=your_r2_secret_access_key
R2_BUCKET_NAME=allai-design-media
# Custom domain mapped to the bucket (Cloudflare dashboard → R2 → bucket → Settings → Public Access → Custom Domain)
R2_PUBLIC_URL=https://cdn.allai.design
